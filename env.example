# Nexus AI Agent Framework Environment Configuration
# Copy this file to .env and update the values for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application
APP_NAME=Nexus AI Agent Framework
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
UI_PORT=3000
CORE_PORT=8080

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nexus_ai
DB_USER=nexus_user
DB_PASSWORD=your_secure_password_here
DB_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# JWT Configuration
JWT_SECRET_KEY=your_super_secret_jwt_key_here_change_this_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password Hashing
PASSWORD_SALT_ROUNDS=12

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# AI MODEL CONFIGURATION
# =============================================================================

# OpenAI (if using)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=4096

# Anthropic (if using)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Local AI Models
LOCAL_MODEL_PATH=/app/models
MODEL_CACHE_SIZE=10GB

# =============================================================================
# DISTRIBUTED COMPUTING
# =============================================================================

# Ray Configuration
RAY_HEAD_HOST=localhost
RAY_HEAD_PORT=10001
RAY_DASHBOARD_PORT=8265
RAY_REDIS_PASSWORD=your_ray_redis_password

# Cluster Configuration
CLUSTER_MODE=false
WORKER_NODES=2
MAX_WORKERS=8

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Prometheus
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana
GRAFANA_ENABLED=true
GRAFANA_PORT=3001

# Logging
LOG_FILE_PATH=/app/logs
LOG_MAX_SIZE=100MB
LOG_BACKUP_COUNT=5

# =============================================================================
# AWS CONFIGURATION (for production deployment)
# =============================================================================

# AWS Credentials
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# S3 Configuration
S3_BUCKET_NAME=nexus-ai-storage
S3_ENDPOINT_URL=https://s3.amazonaws.com

# EKS Configuration
EKS_CLUSTER_NAME=nexus-ai-cluster
EKS_NAMESPACE=nexus-ai

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true

# Email Templates
EMAIL_FROM=noreply@nexus-ai.com
EMAIL_REPLY_TO=support@nexus-ai.com

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# Slack Integration (optional)
SLACK_BOT_TOKEN=your_slack_bot_token
SLACK_SIGNING_SECRET=your_slack_signing_secret

# Discord Integration (optional)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_guild_id

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Development Tools
ENABLE_DEBUG_TOOLBAR=false
ENABLE_PROFILING=false
ENABLE_METRICS=true

# Testing
TEST_DATABASE_URL=postgresql://test_user:test_password@localhost:5432/nexus_ai_test
TEST_REDIS_URL=redis://localhost:6379/1

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/Disable Features
ENABLE_QUANTUM_ALGORITHMS=true
ENABLE_DISTRIBUTED_TRAINING=true
ENABLE_SELF_HEALING=true
ENABLE_ADAPTIVE_LEARNING=true
ENABLE_SYMBIONT_INTERFACE=true

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Memory and CPU Limits
MAX_MEMORY_USAGE=8GB
MAX_CPU_CORES=8
WORKER_TIMEOUT=300

# Cache Settings
CACHE_TTL=3600
CACHE_MAX_SIZE=1GB

# =============================================================================
# BACKUP AND RECOVERY
# =============================================================================

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=nexus-ai-backups

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Alert Configuration
ALERT_EMAIL_ENABLED=true
ALERT_SLACK_ENABLED=false
ALERT_DISCORD_ENABLED=false

# Thresholds
CPU_THRESHOLD=80
MEMORY_THRESHOLD=85
DISK_THRESHOLD=90

# =============================================================================
# API RATE LIMITING
# =============================================================================

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600  # 1 hour

# =============================================================================
# QUANTUM COMPUTING (if available)
# =============================================================================

# IBM Quantum
IBM_QUANTUM_TOKEN=your_ibm_quantum_token
IBM_QUANTUM_BACKEND=ibmq_qasm_simulator

# D-Wave
DWAVE_API_TOKEN=your_dwave_api_token
DWAVE_SOLVER=Advantage_system1.1

# =============================================================================
# MACHINE LEARNING PIPELINE
# =============================================================================

# Model Training
TRAINING_BATCH_SIZE=32
TRAINING_EPOCHS=100
TRAINING_LEARNING_RATE=0.001
TRAINING_VALIDATION_SPLIT=0.2

# Model Serving
MODEL_SERVING_PORT=8081
MODEL_LOAD_TIMEOUT=60

# =============================================================================
# SECURITY MONITORING
# =============================================================================

# Security Scanning
SECURITY_SCAN_ENABLED=true
SECURITY_SCAN_SCHEDULE=0 3 * * *  # Daily at 3 AM
VULNERABILITY_ALERT_ENABLED=true

# =============================================================================
# CUSTOMIZATION
# =============================================================================

# Custom Settings
CUSTOM_THEME=default
CUSTOM_BRANDING=false
CUSTOM_DOMAIN=nexus-ai.local

# =============================================================================
# DEPLOYMENT
# =============================================================================

# Docker Configuration
DOCKER_REGISTRY=ghcr.io
DOCKER_IMAGE_TAG=latest
DOCKER_BUILD_CONTEXT=.

# Kubernetes
K8S_NAMESPACE=nexus-ai
K8S_REPLICAS=3
K8S_RESOURCE_LIMITS_CPU=1000m
K8S_RESOURCE_LIMITS_MEMORY=2Gi 